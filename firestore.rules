rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: caller owns the given household document.
    function isHouseholdOwner(householdId) {
      return request.auth != null
             && exists(/databases/$(database)/documents/households/$(householdId))
             && get(/databases/$(database)/documents/households/$(householdId)).data.ownerId == request.auth.uid;
    }

    // Households
    match /households/{householdId} {
      allow read: if request.auth != null;
      // Anyone signed in can create a household; the creator must be the owner.
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      // Only the current owner may update, and they must not transfer ownership
      // silently (ownerId must remain unchanged via this path).
      allow update: if request.auth != null
                    && resource.data.ownerId == request.auth.uid
                    && request.resource.data.ownerId == resource.data.ownerId;
    }

    // Household membership
    match /householdMembers/{memberId} {
      allow read: if request.auth != null;
      // A user can add themselves to a household, OR the household owner can
      // add anyone. This supports the invite auto-join flow and owner-driven
      // invites.
      allow create: if request.auth != null
                    && (
                      request.auth.uid == request.resource.data.userId
                      || isHouseholdOwner(request.resource.data.householdId)
                    );
      // A user can leave (delete their own membership), or the household
      // owner can remove anyone.
      allow delete: if request.auth != null
                    && (
                      request.auth.uid == resource.data.userId
                      || isHouseholdOwner(resource.data.householdId)
                    );
    }

    // Recipes
    // NOTE: update/delete remain auth-only because recipes carry social
    // fields (lovedBy/dislikedBy/triedBy/mustTry/notes) that any signed-in
    // user legitimately mutates via arrayUnion/arrayRemove, AND recipes have
    // no createdByUid field yet. Tightening these needs a data migration.
    // The [known-permissive] tests in firestore.rules.test.ts pin this.
    match /recipes/{recipeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Family members / profiles
    match /members/{memberId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Meal plans
    match /mealPlans/{planId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Event menus (collections)
    match /collections/{collectionId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Tips & Tricks
    match /tips/{tipId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // User preferences
    match /userPreferences/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Invited users
    // NOTE: public read is intentional — the sign-up flow calls
    // isEmailAllowed() before the user authenticates, to tell them whether
    // they're on an invite list. Tightening to auth-only breaks onboarding.
    // The [known-risk] test in firestore.rules.test.ts pins this.
    match /invitedUsers/{email} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Global config
    match /config/{docId} {
      allow read: if true;
    }
  }
}
